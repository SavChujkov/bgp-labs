!
version 12.4
service timestamps debug datetime msec
service timestamps log datetime msec
no service password-encryption
!
hostname AS-500-R2
!
boot-start-marker
boot-end-marker
!
!
no aaa new-model
memory-size iomem 5
ip cef
!
!
!
!
!
multilink bundle-name authenticated
!
!
!
!
!
!
!
!
!
!
!
!
!
!
!
!
!
!
!
!
!
archive
 log config
  hidekeys
!
!
!
!
!
!
!
!
interface FastEthernet0/0
 ip address 192.168.20.2 255.255.255.252
 speed 100
 full-duplex
!
interface FastEthernet0/1
 ip address 10.0.10.2 255.255.255.252
 speed 100
 full-duplex
!
interface FastEthernet1/0
 no ip address
 shutdown
 duplex auto
 speed auto
!
router bgp 500
 no synchronization
 bgp log-neighbor-changes
 neighbor 10.0.10.1 remote-as 1100
 neighbor 10.0.10.1 send-community
 neighbor 10.0.10.1 route-map DELETE_PRIVATE_COMMUNITIES out
 neighbor 192.168.20.1 remote-as 500
 neighbor 192.168.20.1 next-hop-self
 no auto-summary
!
ip forward-protocol nd
!
ip bgp-community new-format
ip community-list 10 permit 500:200
ip community-list standard PRIVATE_COMM permit 500:200
!
ip http server
no ip http secure-server
!
!
!
!
route-map DELETE_PRIVATE_COMMUNITIES permit 10
 set comm-list PRIVATE_COMM delete
!
route-map DELETE_INTERNAL_COMMUNITY permit 10
 match community 10
 set community none
!
route-map DELETE_INTERNAL_COMMUNITY permit 20
!
!
!
!
control-plane
!
!
!
!
!
!
!
!
!
!
line con 0
line aux 0
line vty 0 4
 login
!
!
end
