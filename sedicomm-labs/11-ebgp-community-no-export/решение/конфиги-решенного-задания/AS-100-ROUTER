 no auto-summary

ip http server
no ip http secure-server

ip prefix-list 10 seq 5 permit 91.55.46.248/30

ip prefix-list 20 seq 5 permit 91.55.46.248/30

route-map ANN_POLICY permit 10
 match ip address prefix-list 10
 set community no-export

route-map ANN_POLICY permit 20

route-map ANN_DENY_2 deny 10
 match ip address prefix-list 20

route-map ANN_DENY_2 permit 20
